[Unit]
Description=Momenta FastAPI Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/momenta/backend
Environment=PYTHONPATH=/opt/momenta/backend
EnvironmentFile=/opt/momenta/backend/.env.production
ExecStart=/opt/momenta/backend/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 10099
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
